# ========================================
# AgroConnect - Project-level .gitignore
# ========================================

# Environment variables (CRITICAL: never commit secrets)
.env
.env.local
.env.*.local
.envrc

# OpenCode local cache, sessions, and state
.opencode/

# Dependencies and virtual environments
node_modules/
venv/
env/

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# IDE and editor files
.vscode/
.idea/
*.swp
*.swo
*~
*.sublime-workspace
*.sublime-project

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Testing & coverage
coverage/
.nyc_output/
*.lcov

# Build outputs (each package has its own .gitignore for specifics)
dist/
build/
.next/
.output/

# Misc
*.tsbuildinfo
.husky/_
.husky/pre-commit

# Temporary files and cache
*.tmp
*.temp
.cache/

# Local Netlify/Vercel folders
.netlify/
.vercel/

# Docker (local environment overrides)
docker-compose.override.yml
